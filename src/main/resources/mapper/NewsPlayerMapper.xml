<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.msc.mapper.NewsPlayerMapper">

    <insert id="batchInsert">
        INSERT INTO news_players (news_id, player_id)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.newsId}, #{item.playerId})
        </foreach>
    </insert>

    <select id="findPlayerIdsByNewsId" resultType="java.lang.Long">
        SELECT player_id
        FROM news_players
        WHERE news_id = #{newsId}
    </select>

    <delete id="deleteByNewsId">
        DELETE FROM news_players WHERE news_id = #{newsId}
    </delete>

    <select id="findNewsIdsByPlayerId" resultType="java.lang.Long">
        SELECT news_id
        FROM news_players
        WHERE player_id = #{playerId}
    </select>

</mapper>