<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.msc.mapper.UserMapper">

    <select id="findByUsername"
            resultType="com.msc.model.entity.User">
        SELECT *
        FROM users
        WHERE username = #{username}
    </select>

    <select id="findById"
            resultType="com.msc.model.entity.User">
        SELECT *
        FROM users
        WHERE id = #{id}
    </select>

    <select id="count" resultType="long">
        select count(*) from users
    </select>

    <select id="page" resultType="com.msc.model.entity.User">
        select *
        from users
        order by created_at desc
            limit #{offset}, #{size}
    </select>

    <insert id="insert"
            parameterType="com.msc.model.entity.User"
            useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO users
            (username, password, role, enabled, created_at, updated_at)
        VALUES
            (#{username}, #{password}, #{role}, #{enabled},
             NOW(), NOW())
    </insert>

    <update id="updateStatus">
        UPDATE users
        SET enabled = #{enabled},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

</mapper>